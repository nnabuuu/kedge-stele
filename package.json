{
  "name": "stele-mcp",
  "version": "0.4.0-snapshot.6",
  "description": "实录 / Stele — carve decisions as they're made, traceable ever after. Local MCP server + SQLite decision-provenance store; primary client is Claude Code.",
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "decision-log",
    "adr",
    "provenance",
    "sqlite"
  ],
  "author": "Xiaochen Nie <zjsnxc@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnabuuu/kedge-stele.git"
  },
  "bugs": {
    "url": "https://github.com/nnabuuu/kedge-stele/issues"
  },
  "homepage": "https://github.com/nnabuuu/kedge-stele#readme",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "bin": {
    "stele": "dist/cli.js",
    "stele-mcp": "dist/mcp.js"
  },
  "files": [
    "dist/",
    "web/",
    "README.md",
    "CHANGELOG.md",
    "DEVELOPING.md",
    "ProductDesign.md",
    "naming-stele.md",
    "LICENSE"
  ],
  "scripts": {
    "_node": "node --experimental-strip-types --no-warnings",
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build",
    "test": "node --test --experimental-strip-types --no-warnings --test-reporter=spec 'src/**/*.test.ts'",
    "seed": "npm run _node -- src/cli.ts seed",
    "list": "npm run _node -- src/cli.ts list",
    "resume": "npm run _node -- src/cli.ts resume",
    "trace": "npm run _node -- src/cli.ts trace",
    "add": "npm run _node -- src/cli.ts add",
    "resolve": "npm run _node -- src/cli.ts resolve",
    "relate": "npm run _node -- src/cli.ts relate",
    "mcp": "npm run _node -- src/mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3"
  }
}
